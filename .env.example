# Copy this file to .env. Never commit the real values.
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5
DATABASE_URL=sqlite:///schedule_assistant.db
# Local development uses http://127.0.0.1:8000 automatically. The Railway
# production build uses the same public address for the UI and API.
VITE_API_URL=http://127.0.0.1:8000

# Use a long random value before deploying the app.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
TOKEN_HOURS=168
